#include "STM32F407xx.h"
#include <stdint.h>

// USART2_TX → PA2
// USART2_RX → PA3

uint8_t read_Ch;
char buffer[20];
uint32_t len;
void USART2_init(void);
void USART2_write(uint8_t ch);
uint8_t USART2_read(void);
void delayMs(int);
void USART2_Writestring(const  char *s);
void USART2_readstring(char *);
int main(void)
{
    USART2_init();
    USART2_writestring("Jagadeesh");
    USART2_readstring(buffer);
}
void USART2_Writestring(const char *s){
	while(*s!='\0'){
		len++;
		USART2_write(*s++);
	}
}
void USART2_readstring(char *rec){
	int i=0;
	while(i<len){
		read_Ch=USART2_read();
		if(read_Ch=='\r'|| read_Ch=='\n'){
			break;
		}
		rec[i]=read_Ch;
		i++;
	}
	rec[i]='\0';

}
void USART2_init(void)
{
    RCC->AHB1ENR |= (1 << 0);    // Enable GPIOA clock
    RCC->APB1ENR |= (1 << 17);   // Enable USART2 clock

    // PA2 → TX (AF7)
    GPIOA->MODER &= ~(3 << 4);
    GPIOA->MODER |=  (2 << 4);
    GPIOA->AFR[0] &= ~(0xF << 8);
    GPIOA->AFR[0] |=  (7 << 8);

    // PA3 → RX (AF7)
    GPIOA->MODER &= ~(3 << 6);
    GPIOA->MODER |=  (2 << 6);
    GPIOA->AFR[0] &= ~(0xF << 12);
    GPIOA->AFR[0] |=  (7 << 12);

    // Pull-up on PA3 (RX)
    GPIOA->PUPDR &= ~(3 << 6);
    GPIOA->PUPDR |=  (1 << 6);

    USART2->BRR = 0x0683;         // 9600 baud
    USART2->CR1 |= (1 << 3);      // TE
    USART2->CR1 |= (1 << 2);      // RE
    USART2->CR1 |= (1 << 13);     // UE
}

void USART2_write(uint8_t ch)
{
    while (!(USART2->SR & (1 << 7)));  // Wait TXE
    USART2->DR = ch;
    while (!(USART2->SR & (1 << 6))); // Wait TC
}

uint8_t USART2_read(void)
{
    while (!(USART2->SR & (1 << 5))); // Wait RXNE
    return USART2->DR;
}

void delayMs(int n)
{
    for (; n > 0; n--)
        for (volatile int i = 0; i < 2000; i++);
}
