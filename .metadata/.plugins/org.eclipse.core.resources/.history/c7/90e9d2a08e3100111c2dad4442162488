#include "gpio_reg.h"
#include "data_acquisition.h"
#include "tinyml.h"
#include "config.h"

int main()
{
    uint8_t data[SAMPLE_SIZE];
    int result;

    TinyML ml;

    GPIO::init();

    while(1)
    {
        DataAcquisition::collect(data);

        result = ml.predict(data);

        if(result == 1)
            GPIO::setPD12();
        else
            GPIO::resetPD12();
    }
}
