#include<STM32F407xx.h>
void delay(void);
class LED{
public:
	LED(){
		RCC->AHB1ENR|=(1<<3);//GPIOD clock is enable;
		RCC->AHB1ENR|=(1<<0);//GPIOA clock is enable

		GPIOA->MODER&=~(3<<0);//PA0 is enable

		GPIOD->MODER&=~(3<<24);//PD12 //green
		GPIOD->MODER|=(1<<24);

		GPIOD->MODER&=~(3<<26);//PD13 orange
		GPIOD->MODER|=(1<<26);

		GPIOD->MODER&=~(3<<28);//PD14 red
		GPIOD->MODER|=(1<<28);

		GPIOD->MODER&=~(3<<30);//PD15 blue
		GPIOD->MODER|=(1<<30);
	}
	void Led_green_toggle(){
		GPIOD->BSRR=(1<<12);
		delay();
	}
	void Led_orange_toggle(){
		GPIOD->BSRR=(1<<13);
		delay();
	}
	void Led_red_toggle(){
			GPIOD->BSRR=(1<<14);
			delay();
		}
	void Led_blue_toggle(){
			GPIOD->BSRR=(1<<15);
			delay();
		}
	bool  Switch_state(){
		return GPIOA->IDR&(1U<<0);
	}
};
