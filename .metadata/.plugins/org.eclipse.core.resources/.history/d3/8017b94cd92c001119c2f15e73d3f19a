		GPIOD->MODER&=~(3<<(pin*2));
		GPIOD->MODER|=(1<<(pin*2));
	}
	static void set(uint8_t pin){
		GPIOD->BSRR|=(1<<pin);
	}
	static void reset(uint8_t pin){
	GPIOD->BSRR|=(1<<pin+16);
	}
	static uint8_t read(uint8_t pin){
		return (GPIOD->ODR>>pin)&1;
	}
	static void toggle(uint8_t pin){
