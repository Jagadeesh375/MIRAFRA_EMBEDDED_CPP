#include "STM32F407xx.h"
#include <stdint.h>

// USART2_TX → PA2
// USART2_RX → PA3

uint8_t read_Ch;

void USART2_init(void);
void USART2_write(uint8_t ch);
uint8_t USART2_read(void);
void delayMs(int);
int main(void)
{
    USART2_init();   // Initialize UART
    char *s="Jagadeesh";
	   while(*s!='\0'){
        USART2_write(*s++);// 1 byte
        read_Ch=USART2_read();
   }
}

void USART2_init(void)
{
    RCC->AHB1ENR |= (1 << 0);   // Enable GPIOA clock
    RCC->APB1ENR |= (1 << 17);  // Enable USART2 clock
    GPIOA->MODER &= ~(3 << 4);
    GPIOA->MODER |=  (2<< 4);   // Alternate function -10
    // created Array :AFR[2]  , AFR[0]=AFRL ,AFR[1]= AFRH
    GPIOA->AFR[0] &= ~(0xF << 8); // AFRL =AFR[0]- Clearing 4 bits
    GPIOA->AFR[0] |=  (7 << 8);   // AF7 (USART3) // 0111 for AF7

    GPIOA->MODER &= ~(3 << 6);
    GPIOA->MODER |=  (2 << 6);// 10 AFR mode
    GPIOA->AFR[0] &= ~(0xF << 12);// AFRL Register
    GPIOA->AFR[0] |=  (7 << 12); // AF7 -0111

    // USART settings
    USART2->BRR = 0x0683;      // 9600 baud @ 16 MHz(HSI)
    USART2->CR1 |= (1 << 3);   // TE
    USART3->CR1 |= (1 << 2);   // RE
    USART2->CR1 |= (1 << 13);  // UE - USART enable
}

/*----------------------------------------------------------
  Write one byte
----------------------------------------------------------*/
void USART2_write(uint8_t ch) //ch ='A'
{
    // Wait until DR empty
    while (!(USART2->SR & (1 << 7)));

    USART2->DR = ch;

    // Wait until transmission complete
    while (!(USART2->SR & (1 << 6)));
}
uint8_t USART2_read(void)
{
    while (!(USART2->SR & (1 << 5))); // RXNE
    return USART2->DR;
}

/*----------------------------------------------------------
  Delay
----------------------------------------------------------*/
void delayMs(int n)
{
    for (; n > 0; n--)
        for (volatile int i = 0; i < 2000; i++);
}
