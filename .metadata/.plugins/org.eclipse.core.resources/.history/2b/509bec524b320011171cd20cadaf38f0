#include <stdint.h>
#include <STM32F407xx.h>

void delay(void) {
    for (volatile uint32_t i = 0; i < 200000; i += 1); // i+=1 fixes C++20 warning
}

class LED {
public:
    LED() {
        RCC->AHB1ENR |= (1<<3); // GPIOD clock
        RCC->AHB1ENR |= (1<<0); // GPIOA clock

        GPIOA->MODER &= ~(3<<0); // PA0 as input

        GPIOD->MODER &= ~(3<<24); GPIOD->MODER |= (1<<24); // PD12 green
        GPIOD->MODER &= ~(3<<26); GPIOD->MODER |= (1<<26); // PD13 orange
        GPIOD->MODER &= ~(3<<28); GPIOD->MODER |= (1<<28); // PD14 red
        GPIOD->MODER &= ~(3<<30); GPIOD->MODER |= (1<<30); // PD15 blue
    }

    void Led_green_toggle()  {
    	GPIOD->ODR ^= (1<<12);
    }
    void Led_orange_toggle(){
    	GPIOD->ODR ^= (1<<13); delay();
    }
    void Led_red_toggle(){
    	GPIOD->ODR ^= (1<<14);
    }
    void Led_blue_toggle(){
    	GPIOD->ODR ^= (1<<15);
    }

    void Led_all_off() {
        // Upper 16 bits of BSRR = RESET pins
        GPIOD->BSRR = (1<<28)|(1<<29)|(1<<30)|(1<<31);
    }

    bool Switch_state() {
        return GPIOA->IDR & (1U<<0);
    }
};

LED obj;
static bool status=false;
int main() {
    LED* L1 = new LED;

    while (1) {
        L1->Led_blue_toggle();
        delay();

        try {
            if (L1->Switch_state() == 1) {
                throw obj;
            }
        }
        catch (const LED& g) {
        	status=true;
            L1->Led_red_toggle();
            L1->Led_blue_toggle();
            L1->Led_orange_toggle();

            for (volatile uint32_t i = 0; i < 300000; i += 1);

            L1->Led_all_off();
        }
        catch (...) {
            L1->Led_all_off();
        }
    }

    return 0;
}
