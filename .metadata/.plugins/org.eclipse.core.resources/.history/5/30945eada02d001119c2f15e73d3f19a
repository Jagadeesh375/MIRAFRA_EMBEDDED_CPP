/*******************************************************************************
 * @file    : main.c
 * @brief   : USART3 Transmit Example - STM32F405
 * PC10 = TX, PC11 = RX, Baud = 9600, 72MHz clock
 *******************************************************************************/

#include <stdint.h>
#include "STM32F407xx.h"

void USART3_init(void)
{
    /* Step 1: Enable Clocks */
    RCC->APB1ENR |= (1 << 18);   // USART3 clock enable
    RCC->AHB1ENR |= (1 << 2);    // GPIOC clock enable

    /* Step 2: Configure PC10 as TX (Alternate Function 7) */
    GPIOC->MODER  &= ~(3 << 20);  // Clear bits [21:20]
    GPIOC->MODER  |=  (2 << 20);  // Set Alternate Function mode

    GPIOC->AFR[1] &= ~(0xF << 8); // Clear AFR for pin10 (AFRH bits [11:8])
    GPIOC->AFR[1] |=  (0x7 << 8); // AF7 = USART3_TX

    /* Step 3: Configure PC11 as RX (Alternate Function 7) */
    GPIOC->MODER  &= ~(3 << 22);   // Clear bits [23:22]
    GPIOC->MODER  |=  (2 << 22);   // Set Alternate Function mode

    GPIOC->AFR[1] &= ~(0xF << 12); // Clear AFR for pin11 (AFRH bits [15:12])
    GPIOC->AFR[1] |=  (0x7 << 12); // AF7 = USART3_RX

    /* Step 4: Configure Baud Rate */
    USART3->BRR = 0x0683;           // 9600 baud @ 42MHz APB1 clock

    /* Step 5: Enable TX, RX, then USART (UE must be LAST) */
    USART3->CR1 |= (1 << 3);        // TE  = 1 (Transmitter Enable)
    USART3->CR1 |= (1 << 2);        // RE  = 1 (Receiver Enable)
    USART3->CR1 |= (1 << 13);       // UE  = 1 (USART Enable) ← Last!
}

void USART3_write(uint8_t ch)
{
    /* Wait until TXE = 1 (Transmit Data Register Empty) */
    while (!(USART3->SR & (1 << 7)));  // bit7 = TXE

    /* Write data to DR */
    USART3->DR = ch;

    /* Wait until TC = 1 (Transmission Complete) */
    while (!(USART3->SR & (1 << 6)));  // bit6 = TC
}

int main(void)
{
    USART3_init();

    while (1) {
        USART3_write('A');
    }
}
