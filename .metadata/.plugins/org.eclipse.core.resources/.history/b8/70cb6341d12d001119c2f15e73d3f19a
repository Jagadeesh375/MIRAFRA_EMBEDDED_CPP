#include "STM32F405xx.h"
#include <cstdint>

template<std::uintptr_t BASE>
struct GPIO_Port {
    static GPIO_TypeDef* port() {
        return reinterpret_cast<GPIO_TypeDef*>(BASE);
    }
    static void enable_clock() {
        static bool enabled = false;
        if (!enabled) {
            if(BASE == GPIOA_BASE){
            	RCC->AHB1ENR |= (1U << 0);
            }
            else if(BASE == GPIOB_BASE){
            	RCC->AHB1ENR |= (1U << 1);
            }
            else if(BASE == GPIOC_BASE){
            	RCC->AHB1ENR |= (1U << 2);
            }
            else if(BASE == GPIOD_BASE){
            	RCC->AHB1ENR |= (1U << 3);
            }
            else if(BASE == GPIOE_BASE){
            	RCC->AHB1ENR |= (1U << 4);
            }
            enabled = true;
        }
    }
};
template<typename Port, uint8_t PIN>
class GPIO_Pin {
public:
    static_assert(PIN < 16, "Pin must be 0-15");

    static void set_output() {
        Port::enable_clock();
        Port::port()->MODER &= ~(3U << (PIN * 2U));
        Port::port()->MODER |=  (1U << (PIN * 2U));
    }
    static void set(){
    	Port::port()->BSRR = (1U << PIN);
    }
    static uint8_t button(){
    	return (Port::port()->IDR>>PIN)&1;
    }
    static void reset(){
    	Port::port()->BSRR = (1U << (PIN + 16U));
    }
    static void toggle() {
        if ((Port::port()->ODR >> PIN) & 1U){
        	reset();
        }
        else{
        	set();
        }
    }
    static void set_input() {
        Port::enable_clock();
        Port::port()->MODER &= ~(3U << (PIN * 2U)); // 00 = Input
    }
};

template<typename PIN,bool status>
class LED {
public:
    LED(){
    	if(status){
    	PIN::set_output();
    	}
    	else{
    		PIN::set_input();
    	}
    }
    void on(){
    	PIN::set();
    }
    void off(){
    	PIN::reset();
    }
    void toggle(){
    	PIN::toggle();
    }
    uint8_t read(){
    	return PIN::button();
    }

};

void delay() {
    for (volatile uint32_t i = 0; i < 200000U; ++i) {
        __asm volatile("nop");
    }
}

using PortA = GPIO_Port<GPIOA_BASE>;
using PortB = GPIO_Port<GPIOB_BASE>;
using PortC = GPIO_Port<GPIOC_BASE>;
using PortD = GPIO_Port<GPIOD_BASE>;
using PortE = GPIO_Port<GPIOE_BASE>;

using PD14 = GPIO_Pin<PortD,14>;
using PD15 = GPIO_Pin<PortD,15>;
using PB5  = GPIO_Pin<PortB,5>;
using PC3  = GPIO_Pin<PortC,3>;
using PE4  = GPIO_Pin<PortE,4>;
using PA1=GPIO_Pin<PortA,1>;
int main() {
  LED<PD14,1> red;
    LED<PD15,1> blue;
    LED<PB5,1>  ext1;
    LED<PC3,1>  ext2;
    LED<PE4,1>  ext3;
    LED<PA1,0> b;
    while (true) {
    	if(b.read()==1){
        ext1.toggle();
        delay();
        ext2.toggle();
        delay();
        ext3.toggle();
        delay();

    	}
    	else if(b.read()==0){
    	red.toggle();
    	        delay();
    	        blue.toggle();
    	        delay();
    }
    }
}
