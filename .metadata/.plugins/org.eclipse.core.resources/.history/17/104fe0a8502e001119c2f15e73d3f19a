#include "STM32F407xx.h"
#include <stdint.h>

// USART2_TX → PA2
// USART2_RX → PA3
// LED → PD15

void USART2_init(void);
uint8_t USART2_read(void);
void LED_init(void);
int main(void)
{
    USART2_init();
    LED_init();
    while (1)
    {
        uint8_t ch = USART2_read(); // wait for input

        if (ch == '1')
        {
            GPIOD->BSRR = (1 << 12);         // LED ON
        }
        else if (ch == '0')
        {
            GPIOD->BSRR = (1 << (12 + 16));  // LED OFF
        }
    }
}

void USART2_init(void)
{
    RCC->AHB1ENR |= (1 << 0);   // Enable GPIOA clock
    RCC->APB1ENR |= (1 << 17);  // Enable USART2 clock

    // PA2→ TX (AF7)
    GPIOA->MODER &= ~(3 << 4);
    GPIOA->MODER |=  (2 << 4);
    GPIOA->AFR[0] &= ~(0xF << 8);
    GPIOA->AFR[0] |=  (7 << 8);

    // PA3 → RX (AF7)
    GPIOA->MODER &= ~(3 << 6);
    GPIOA->MODER |=  (2 << 6);
    GPIOA->AFR[0] &= ~(0xF << 12);
    GPIOA->AFR[0] |=  (7 << 12);

    //  Important: Enable pull-up for RX
    GPIOA->PUPDR &= ~(3 << 6);
    GPIOA->PUPDR |=  (1 <<6);

    // USART configuration
    USART2->BRR = 0x008B;       // 115200 baud @ 16 MHz

    USART2->CR1 |= (1 << 3);    // TE (Transmit enable)
    USART2->CR1 |= (1 << 2);    // RE (Receive enable)
    USART2->CR1 |= (1 << 13);   // UE (USART enable)
}
uint8_t USART2_read(void)
{
    while (!(USART2->SR & (1 << 5))); // Wait for RXNE
    return USART2->DR;
}

void LED_init(void)
{
    RCC->AHB1ENR |= (1 << 3); // Enable GPIOD clock

    GPIOD->MODER &= ~(3 << (15 * 2));
    GPIOD->MODER |=  (1 << (15 * 2)); // Output mode
}
