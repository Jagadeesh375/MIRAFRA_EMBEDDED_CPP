#include <stdint.h>
#include"STM32F405xx.h"
void USART3_init(){
	RCC->APB1ENR=(1<<18);//enable USART clock
	RCC->AHB1ENR=(1<<2);//enable GPIO_PORTC clock
	//TX
	GPIOC->MODER&=~(3<<20);//clear PORTC pin10
	GPIOC->MODER|=(2<<20);//enable alternate functionality
	//AFR[2]->array where AFR[0]->AFRL(0-7)  AFR[1]->AFRH(8-15)
	GPIOC->AFR[1]&=~(0xF<<8);
	GPIOC->AFR[1]|=(0x7<<8);

	//RX
	GPIOC->MODER&=~(3<<22);
	GPIOC->MODER|=(2<<22);
	GPIOC->AFR[1]&=(0xF<<12);
	GPIOC->AFR[1]|=(0x7<<12);

	USART3->BRR=0x0683;//baurd rate 9600
	USART3->CR1|=(1<<3);//enable TX
	USART3->CR1|=(1<<2);//enable RX
	USART3->CR1|=(1<<13);
}
void USART3_write(uint8_t ch){
	while(!(USART3->SR)&(1<<7));//check whaeather TXE(tranmission data empty register)
	USART3->DR=ch;
	while(!(USART3->SR)&(1<<6));//check whearher TC status
}

int main(void)
{
	USART3_init();
	while(1){
		USART3_write('A');
	}
}
