#include "STM32F405xx.h"
#include <cstdint>
template<GPIO_TypeDef* PORT>
struct GPIO_Port {
	static constexpr GPIO_TypeDef* port = PORT;
    static void enable_clock() {
        static bool enabled = false;
        if (!enabled) {
            if(PORT == GPIOA){
            	RCC->AHB1ENR |= (1 << 0);
            }
            else if(PORT == GPIOB){
            	RCC->AHB1ENR |= (1 << 1);
            }
            else if(PORT == GPIOC){
            	RCC->AHB1ENR |= (1 << 2);
            }
            else if(PORT == GPIOD) {
            	RCC->AHB1ENR |= (1 << 3);
            }
            else if(PORT == GPIOE){
            	RCC->AHB1ENR |= (1 << 4);
            }
            else if(PORT == GPIOF){
            	RCC->AHB1ENR |= (1 << 5);
            }
            else if(PORT == GPIOG){
            	RCC->AHB1ENR |= (1 << 6);
            }
            else if(PORT == GPIOH){
            	RCC->AHB1ENR |= (1 << 7);
            }
            else if(PORT == GPIOI){
            	RCC->AHB1ENR |= (1 << 8);
            }

            volatile uint32_t dummy = RCC->AHB1ENR; // stabilization
            (void)dummy;

            enabled = true;
        }
    }
};

template<typename Port, uint8_t PIN>
class GPIO_Pin {
public:
    static_assert(PIN < 16, "Pin must be 0–15");

    static void set_output() {
        Port::enable_clock();
        Port::port->MODER&=~(3U<<(PIN * 2));
        Port::port->MODER|=(1U <<(PIN * 2));
    }

    static void set() {
        Port::port->BSRR=(1U << PIN);
    }

    static void reset() {
        Port::port->BSRR=(1U << (PIN + 16));
    }
    static void toggle() {
        if ((Port::port->ODR>>PIN)&1)
            reset();
        else
            set();
    }
};

template<typename PIN>
class LED {
public:
    LED() {
        PIN::set_output();
    }

    void on(){
    	PIN::set();
    }
    void off(){
    	PIN::reset();
    }
    void toggle(){
    	PIN::toggle();
    }
};

// =======================================================
// 4. Delay Function
// =======================================================
void delay() {
    for (volatile uint32_t i = 0; i < 200000; ++i) {
        __asm volatile("nop");
    }
}

// =======================================================
// 5. Port Aliases
// =======================================================
using PortA = GPIO_Port<GPIOA>;
using PortB = GPIO_Port<GPIOB>;
using PortC = GPIO_Port<GPIOC>;
using PortD = GPIO_Port<GPIOD>;
using PortE = GPIO_Port<GPIOE>;

// =======================================================
// 6. Pin Aliases (Clean & Scalable)
// =======================================================

// On-board LEDs (STM32F407 Discovery)
using PD12 = GPIO_Pin<PortD, 12>;
using PD13 = GPIO_Pin<PortD, 13>;
using PD14 = GPIO_Pin<PortD, 14>;
using PD15 = GPIO_Pin<PortD, 15>;

// External pins
using PB5  = GPIO_Pin<PortB, 5>;
using PC3  = GPIO_Pin<PortC, 3>;
using PE7  = GPIO_Pin<PortE, 7>;
using PA0  = GPIO_Pin<PortA, 0>;
int main() {
    LED<PD12> green;
    LED<PD13> orange;
    LED<PD14> red;
    LED<PD15> blue;
    LED<PB5> ext1;
    LED<PC3> ext2;
    LED<PE7> ext3;
    LED<PA0> ext4;

    while (1) {
        green.toggle();
        delay();
        orange.toggle();
        delay();
        red.toggle();
        delay();
        blue.toggle();
        delay();

        ext1.toggle();
        delay();
        ext2.toggle();
        delay();
        ext3.toggle();
        delay();
        ext4.toggle();
        delay();
    }
}

