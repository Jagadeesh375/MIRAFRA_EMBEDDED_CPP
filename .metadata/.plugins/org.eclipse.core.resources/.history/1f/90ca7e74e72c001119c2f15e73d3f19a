class LED{
public:
	GPIO_TypeDef *pgpio;
	uint8_t pin;
	LED(GPIO_TypeDef port,uint8_t p){
		pgpio(port);
		pin(p);
		RCC->AHB1ENR|=(1U<<3);
		pgpio->MODER&=~(3U<<(pin*2));
		pgpio->MODER|=(1U<<(pin*2));
	}
