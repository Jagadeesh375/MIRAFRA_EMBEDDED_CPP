void USART2_init(void)
{
    RCC->AHB1ENR |= (1 << 0);   // Enable GPIOA clock
    RCC->APB1ENR |= (1 << 17);  // Enable USART2 clock

    // PC10 → TX
    GPIOA->MODER &= ~(3 << 4); // pin10 =pin*2, claered the bits
    GPIOC->MODER |=  (2<< 4);   // Alternate function -10
    // created Array :AFR[2]  , AFR[0]=AFRL ,AFR[1]= AFRH
    GPIOC->AFR[0] &= ~(0xF << 8); // AFRL =AFR[0]- Clearing 4 bits
    GPIOC->AFR[1] |=  (7 << 8);   // AF7 (USART3) // 0111 for AF7

    // PC11 → RX
    GPIOA->MODER &= ~(3 << 6);
    GPIOC->MODER |=  (2 << 6);// 10 AFR mode
    GPIOC->AFR[0] &= ~(0xF << 12);// AFRL Register
    GPIOC->AFR[0] |=  (7 << 12); // AF7 -0111

    // USART settings
    USART2->BRR = 0x0683;      // 9600 baud @ 16 MHz(HSI)
    USART2->CR1 |= (1 << 3);   // TE
    //USART3->CR1 |= (1 << 2);   // RE
    USART2->CR1 |= (1 << 13);  // UE - USART enable
}

/*----------------------------------------------------------
  Write one byte
----------------------------------------------------------*/
void USART2_write(uint8_t ch) //ch ='A'
{
    // Wait until DR empty
    while (!(USART2->SR & (1 << 7))); // TXE =0 while(!0) - while loop(true)
    //TXE=1 Data in DR register will be given to shift register

    USART2->DR = ch; // new data will be loaded to DR

    // Wait until transmission complete
    while (!(USART2->SR & (1 << 6))); // TC=0 while(!0) while(T) waiting
}
